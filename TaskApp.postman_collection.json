{
  "info": {
    "name": "TaskApp API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" }
  ],
  "item": [
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Write quarterly report\",\n  \"description\": \"Summarize Q2 results\",\n  \"status\": \"OPEN\",\n  \"priority\": \"HIGH\"\n}"
        },
        "url": "{{baseUrl}}/tasks"
      }
    },
    {
      "name": "Get Task By Id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/tasks/REPLACE_WITH_ID"
      }
    },
    {
      "name": "List All Tasks",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/tasks"
      }
    },
    {
      "name": "Filter Tasks",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/tasks?status=OPEN&priority=HIGH",
          "host": ["{{baseUrl}}"],
          "path": ["tasks"],
          "query": [
            { "key": "status", "value": "OPEN" },
            { "key": "priority", "value": "HIGH" }
          ]
        }
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Write quarterly report\",\n  \"description\": \"Updated\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"HIGH\"\n}"
        },
        "url": "{{baseUrl}}/tasks/REPLACE_WITH_ID"
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/tasks/REPLACE_WITH_ID"
      }
    }
  ]
}
